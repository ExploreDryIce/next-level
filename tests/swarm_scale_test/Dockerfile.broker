FROM python:3.11-slim

WORKDIR /app
COPY src/swarm/ /app/src/swarm/
COPY src/__init__.py /app/src/__init__.py

# Minimal deps for broker
RUN pip install --no-cache-dir nats-py 2>/dev/null || true

ENV PYTHONPATH=/app
EXPOSE 9876

CMD ["python", "-m", "src.swarm.broker", "--host", "0.0.0.0", "--port", "9876"]
